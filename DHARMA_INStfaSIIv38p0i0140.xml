                    <l n="9">Āṅkavaṉ ṟēviyar ōṅkeḻil muṭi<lb n="6" break="no"/>yum</l>
                    <l n="10">muṉṉavar pakkal teṉṉavaṉ vaitta</l>
                    <l n="11">cun=tara muṭiyum Intira<choice><orig>n</orig><reg>ṉ</reg></choice> āramum</l>
                    <l n="12">te<lb n="7" break="no"/>ṉṟicai y-īḻa maṇṭala<surplus>ṉ</surplus> mu<choice><sic>ṉu</sic><corr>ḻu</corr></choice>vatum</l>
                    <l n="13">Eṟipaṭai-k kēraḷaṉ muṟaimaiyiṟ cūṭu<hi rend="grantha">M</hi></l>
                    <l n="14">kulataṉa<lb n="8" break="no"/>m ākiya palarpukaḻ muṭiyuñ</l>
